# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
# EAS local credentials (distribution cert, profiles, ASC API key, credentials.json)
/build/
credentials.json
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# sentry-wizard binary (106MB; downloaded per setup script)
sentry-wizard

# Supabase CLI local state (keep migrations + config + schema snapshot; ignore everything else)
/supabase/*
!/supabase/migrations/
!/supabase/config.toml
!/supabase/schema.sql

# macOS
.DS_Store
*.pem

# local env files — defensive, catches stray copies like .env.functions.local2
.env
.env.*
!.env.example

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# @bacons/apple-targets plugin-generated artifacts (regenerated on prebuild)
targets/**/generated.entitlements
# NOTE: targets/imessage/Assets.xcassets is hand-authored (the iMessage App
# Icon set), NOT plugin-generated, so it IS committed. We no longer set an
# `icon` field, so the plugin won't generate/overwrite a catalog there.

# Vim swap files
*.swp
